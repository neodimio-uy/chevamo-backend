rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@neodimio[.]com[.]uy$');
    }

    // Alertas: cualquier usuario autenticado puede leer, solo admins escriben
    match /alerts/{alertId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Overrides de paradas: misma regla
    match /stop_overrides/{stopId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Config admin: documentos clave-valor que controlan estado global del
    // sistema (killswitches por feature, modo emergencia, umbrales de
    // anti-vandalismo). Cloud Functions usan admin SDK (bypass rules), iOS
    // autentica con signInAnonymously antes de cualquier lectura → isAuth()
    // cubre ambos casos sin filtrar config interna a scrapers anónimos.
    match /config/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Incidents: eventos operativos (paros, accidentes, desvíos, fallas).
    // Lectura para autenticados (incluye anónimos) — la app autentica antes.
    // Escritura solo admin.
    match /incidents/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Bus overrides: correcciones manuales del admin sobre buses del feed
    // STM (marcar fuera de servicio, override de coordenadas/línea).
    // Lectura para autenticados; escritura admin.
    match /bus_overrides/{busId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Custom stops: paradas creadas manualmente por el admin que no
    // existen en el feed STM. Lectura para autenticados, escritura admin.
    match /custom_stops/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Line overrides: control admin sobre líneas (suspender línea entera,
    // marcar variante custom). Lectura para autenticados, escritura admin.
    match /line_overrides/{lineId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Push events: telemetry de envíos FCM. Solo admin lee/escribe (las
    // Cloud Functions escriben con admin SDK, bypasean rules).
    match /push_events/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Users: doc por usuario con metadata operativa (tier, banned, strikes,
    // notas admin, stats). El propio user lee/escribe su propio doc para
    // hacer upsert al login (lastSeenAt + device info). El admin lee todo
    // y modifica banned/tier/strikes/adminNotes.
    match /users/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      // El user solo puede escribir campos de identidad básica (uid, email,
      // displayName, lastSeenAt, device, createdAt). NO puede setear su
      // propio tier, banned, strikes ni adminNotes — eso es admin-only.
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (!('tier' in request.resource.data) || request.resource.data.tier in ['anonymous', 'basic'])
        && (!('banned' in request.resource.data) || request.resource.data.banned == false)
        && (!('strikes' in request.resource.data) || request.resource.data.strikes == 0);
      allow update: if (request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tier', 'banned', 'banReason', 'bannedAt', 'bannedBy', 'strikes', 'adminNotes']))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // Community buses: cualquiera lee, solo el dueño escribe con validación
    match /community_buses/{docId} {
      allow read: if true;

      // Create: validar campos requeridos y que el userId coincida.
      // `officialBusId` es opcional — solo se setea desde el flujo
      // "Voy en este bus" del widget oficial; cuando está, el frontend
      // matchea por id exacto y evita duplicación visual del bus.
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'line', 'company', 'lat', 'lng', 'updatedAt'])
        && request.resource.data.keys().hasOnly([
            'userId', 'line', 'lineVariantId', 'company',
            'origin', 'destination',
            'lat', 'lng', 'speed',
            'updatedAt', 'startedAt',
            'officialBusId'
          ])
        && request.resource.data.line is string
        && request.resource.data.line.size() > 0
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        // Validar que las coordenadas estén en Uruguay (bounding box amplio)
        && request.resource.data.lat > -36.0 && request.resource.data.lat < -30.0
        && request.resource.data.lng > -59.0 && request.resource.data.lng < -53.0;

      // Update: solo el dueño. No puede cambiar campos de identidad
      // (userId, line, lineVariantId, company, startedAt) ni introducir
      // campos nuevos no managed por el cliente — esto cierra el gap de
      // que un cliente intente escribir reputationScore/trustLevel/etc.
      // Solo se permite mutar las posiciones (lat/lng/speed) y el
      // updatedAt heartbeat. officialBusId también es modificable porque
      // se setea cuando el match con bus oficial cambia.
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.line == resource.data.line
        && request.resource.data.lineVariantId == resource.data.lineVariantId
        && request.resource.data.company == resource.data.company
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lat', 'lng', 'speed', 'updatedAt', 'destination', 'officialBusId']);

      // Delete: solo el dueño
      allow delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // User tokens: solo el dueño puede leer/escribir su propio token
    match /user_tokens/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Live activity tokens: solo backend escribe (via admin SDK)
    match /live_activity_tokens/{docId} {
      allow read: if false;
      allow write: if false;
      // Backend usa admin SDK que bypasea rules
    }

    // Activity feed: admins leen y escriben, usuarios apps NO acceden
    match /activity_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // inmutables una vez escritos
    }

    // Audit log: admins leen, crear desde dashboard, inmutables
    match /audit_log/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Feature flags: lectura para autenticados (apps las consumen tras
    // signInAnonymously), escritura solo admin. Evita filtrar el roadmap a
    // scrapers anónimos.
    match /feature_flags/{flagId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Support tickets: el dueño lee/responde sus propios tickets; admin todo.
    // Schema canónico definido en admin/src/lib/extended-types.ts (SupportTicket).
    // El user puede agregar replies (arrayUnion de 1 elemento por update) pero
    // no puede mutar campos sensibles (userId, subject, priority, assignedTo).
    match /support_tickets/{ticketId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);

      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['subject', 'body', 'status', 'userId', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.subject is string
        && request.resource.data.body is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 200
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 5000
        && request.resource.data.status == 'open'
        && request.resource.data.replies.size() == 0;

      allow update: if isAdmin()
        || (isAuth()
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.subject == resource.data.subject
            && request.resource.data.priority == resource.data.priority
            && request.resource.data.assignedTo == resource.data.assignedTo
            // user solo puede appendear de a 1 reply por update — evita flood.
            && request.resource.data.replies.size() >= resource.data.replies.size()
            && request.resource.data.replies.size() <= resource.data.replies.size() + 1);

      allow delete: if false; // tickets nunca se eliminan, solo se cierran
    }

    // Briefings guardados (opcional, para histórico)
    match /briefings/{briefingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Alert templates: admin CRUD, lectura solo admin (template system)
    match /alert_templates/{templateId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Admin presence: cada admin solo escribe su propio doc (uid == auth.uid), todos leen
    match /admin_presence/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin() && uid == request.auth.uid;
    }

    // Telemetría ETA: cada usuario escribe sus propias observaciones de
    // predicción↔arrival para alimentar el dataset de auto-calibración +
    // futuro entrenamiento de modelo. Solo el dueño lee. Inmutable
    // (no update/delete) — la app nunca modifica un evento ya subido.
    // Validación mínima de schema para impedir inserts arbitrarios.
    match /eta_observations/{uid}/items/{itemId} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth() && request.auth.uid == uid
        && request.resource.data.keys().hasAll([
            'busId', 'stopId', 'line', 'source',
            'predictedSec', 'predictedAt',
            'actualSec', 'actualAt',
            'hourBand', 'dayOfWeek',
            'isRaining', 'smoothedSpeedKmh',
            'intermediateStops', 'distanceMeters'
          ])
        && request.resource.data.busId is string
        && request.resource.data.busId.size() < 64
        && request.resource.data.stopId is int
        && request.resource.data.stopId > 0
        && request.resource.data.line is string
        && request.resource.data.line.size() < 16
        && request.resource.data.source in ['intendencia', 'vamo', 'community']
        && request.resource.data.predictedSec is number
        && request.resource.data.actualSec is number
        && request.resource.data.hourBand is int
        && request.resource.data.hourBand >= 0
        && request.resource.data.hourBand < 24
        && request.resource.data.dayOfWeek is int
        && request.resource.data.dayOfWeek >= 1
        && request.resource.data.dayOfWeek <= 7
        && request.resource.data.distanceMeters is number
        && request.resource.data.distanceMeters >= 0
        && request.resource.data.distanceMeters < 10000;
      allow update, delete: if false;
    }

    // Conexiones: cada user puede leer/escribir su propio grafo de
    // contactos. La aceptación inicial se hace vía Cloud Function
    // (acceptContactInvitation) que escribe ambos lados con privilegios
    // — desde el cliente solo se permiten cambios sobre el propio doc
    // (renombrar/bloquear/eliminar).
    match /user_connections/{ownerUid}/contacts/{contactUid} {
      allow read: if isAuth() && request.auth.uid == ownerUid;
      // El cliente puede actualizar/eliminar entradas de su propio grafo
      // (cambiar nickname, bloquear, eliminar). NO puede crear desde
      // cero — eso lo hace solo la Cloud Function tras validar invitación.
      allow update, delete: if isAuth() && request.auth.uid == ownerUid;
      allow create: if false;
    }

    // Invitaciones de contacto: lectura pública por código (cualquiera con
    // el link puede previsualizar quién invita). Creación: el dueño con
    // un campo fromUid == auth.uid. Updates: solo el dueño puede setear
    // `rejected` desde el cliente; el accept lo hace la Cloud Function.
    match /contact_invitations/{code} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.keys().hasAll(['fromUid', 'fromDisplayName', 'createdAt', 'expiresAt'])
        && request.resource.data.keys().hasOnly([
            'fromUid', 'fromDisplayName', 'fromEmail',
            'createdAt', 'expiresAt'
          ])
        && request.resource.data.fromDisplayName is string
        && request.resource.data.fromDisplayName.size() <= 80;
      // Update: cualquier auth user puede marcar `rejected` (el sender
      // cancela su invitación O el receptor la rechaza desde la pantalla
      // de invitación entrante). Solo se permite mutar `rejected` y
      // `acceptedAt`; el accept real se hace via Cloud Function.
      allow update: if isAuth()
        && !resource.data.acceptedBy
        && resource.data.fromUid != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rejected', 'acceptedAt']);
      // Delete: solo el sender (limpieza opcional si no quiere dejar
      // rastro de invitaciones rechazadas).
      allow delete: if isAuth() && resource.data.fromUid == request.auth.uid;
    }

    // Shared trips: viajes compartidos entre usuarios conectados.
    // Read: el dueño o cualquiera de los recipientes.
    // Create: solo el propio dueño con su uid en ownerId, status inicial
    //         "active" y al menos 1 recipient.
    // Update: solo el dueño puede mutar campos de status, snapshot, updatedAt.
    // Delete: nadie desde cliente — la Cloud Function de cleanup los archiva.
    match /shared_trips/{shareId} {
      allow read: if isAuth()
        && (resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.recipientIds);

      allow create: if isAuth()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.recipientIds is list
        && request.resource.data.recipientIds.size() > 0
        && request.resource.data.recipientIds.size() <= 20
        && request.resource.data.status == "active"
        && request.resource.data.type in ["live_trip", "planned_trip"]
        && request.resource.data.busLine is string
        && request.resource.data.busLine.size() > 0
        && request.resource.data.busLine.size() < 16;

      allow update: if isAuth()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.recipientIds == resource.data.recipientIds
        && request.resource.data.type == resource.data.type;

      allow delete: if false;
    }

    // Códigos de referido: read público (cualquiera con el código puede
    // ver a quién pertenece para canjearlo), create solo del dueño con su
    // ownerUid, update solo via Cloud Function (cliente no puede mutar
    // signups directamente — eso lo hace `redeemReferralCode`).
    match /referral_codes/{code} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerUid', 'createdAt', 'signups'])
        && request.resource.data.keys().hasOnly(['ownerUid', 'createdAt', 'signups'])
        && request.resource.data.signups == 0;
      allow update, delete: if false;  // mutaciones via Cloud Function
    }

    // Eventos de referido: solo Cloud Function escribe. El cliente puede
    // leer su propio evento (para saber si fue referido) pero nunca otros.
    match /referrals/{eventId} {
      allow read: if isAuth()
        && (resource.data.referrerUid == request.auth.uid
            || resource.data.referredUid == request.auth.uid);
      allow write: if false;  // solo Cloud Function con admin SDK
    }

    // ─────────────────────────────────────────────────────────────────────
    // Modo Taxi/Remis (Vamo marketplace propio — Etapa 1 stubs 2026-04-27)
    //
    // Cliente (passenger) NO escribe directo a Firestore — todo va via
    // Cloud Functions /rides (auth en backend, validación Zod, timeline
    // server-side). Cliente solo LEE su propio ride (active + history).
    // ─────────────────────────────────────────────────────────────────────

    // rideRequests: passenger lee solo los suyos. Driver matched lee el suyo
    // (etapa 2 sumará claim del driver vía driverIdMatched).
    match /rideRequests/{requestId} {
      allow read: if isAuth()
        && resource.data.passengerId == request.auth.uid;
      // Toda escritura va via Cloud Function (validación + timeline server-side)
      allow write: if false;
    }

    // trips: snapshots inmutables. Passenger y driver involucrados pueden leer.
    match /trips/{tripId} {
      allow read: if isAuth()
        && (resource.data.passengerId == request.auth.uid
            || resource.data.driverId == request.auth.uid);
      allow write: if false;
    }

    // drivers: cada driver lee su propio doc; admins listan todos.
    // Etapa 2 sumará flow de auto-registro (POST /drivers/me/register).
    match /drivers/{driverId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;  // backend (registro + admin verification)
    }

    // vehicles: el driver dueño lee; admins listan.
    match /vehicles/{vehicleId} {
      allow read: if isAuth()
        && (get(/databases/$(database)/documents/drivers/$(resource.data.driverId)).data.userId == request.auth.uid
            || isAdmin());
      allow write: if false;
    }

    // pricing: lectura para autenticados (UI muestra estimaciones tarifa
    // ride-hailing); escritura solo admin.
    match /pricing/{jurisdictionId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────
    // Wallet / Payments (Mercado Pago — multi-país)
    //
    // wallets/{userId_country}: tarjetas guardadas + mpCustomerId. Solo el
    // dueño lee. Toda escritura via Cloud Function (PCI: cliente nunca toca
    // PAN/CVV; tokeniza con MP_PUBLIC_KEY y manda card_token al backend).
    // ─────────────────────────────────────────────────────────────────────
    match /wallets/{walletId} {
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow write: if false;  // solo Cloud Function
    }

    // payments: snapshots de cobros. Pasajero lee los suyos.
    match /payments/{paymentId} {
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Catch-all: denegar todo lo que no esté explícitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
