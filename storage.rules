rules_version = '2';

// Reglas de Firebase Storage para Vamo.
// Lo único que vivimos en Storage hoy son los adjuntos de tickets de soporte
// (capturas de pantalla que el usuario sube al reportar un problema). Si en
// el futuro agregamos más uso, sumamos paths específicos — el default es
// rechazar todo.
service firebase.storage {
  match /b/{bucket}/o {

    // Adjuntos de soporte: `support_attachments/{ticketId}/{file}`.
    //
    // - Lectura: el doc del ticket vive en Firestore con `userId == request.auth.uid`
    //   o el caller es admin (@neodimio.com.uy). Como Storage no puede leer
    //   Firestore en sus rules, validamos a través de `customMetadata.ownerUid`
    //   que se setea al subir + email admin.
    // - Escritura: solo el dueño del ticket puede subir, y solo si el
    //   ownerUid del metadata matchea su uid. Tamaño max 5 MB y JPEG.
    match /support_attachments/{ticketId}/{file} {
      allow read: if request.auth != null && (
        // Owner: leyó del propio metadata.
        request.auth.uid == resource.metadata.ownerUid
        // Admin: email Neodimio verificado.
        || (request.auth.token.email_verified == true
            && request.auth.token.email.matches('.*@neodimio[.]com[.]uy$'))
      );
      allow create: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg'
        && request.resource.metadata.ownerUid == request.auth.uid;
      // No queremos updates (los adjuntos son inmutables) ni deletes desde
      // cliente — la limpieza la hace el backend si hace falta.
      allow update, delete: if false;
    }

    // Default deny para cualquier otro path.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
